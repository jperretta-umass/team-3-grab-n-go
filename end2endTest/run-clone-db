#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

cd "${PROJECT_ROOT}"

if [ -f .env ]; then
  set -a
  # shellcheck disable=SC1091
  source .env
  set +a
fi

: "${POSTGRES_USER:?Need POSTGRES_USER in .env or the environment}"
: "${POSTGRES_PASSWORD:?Need POSTGRES_PASSWORD in .env or the environment}"
: "${POSTGRES_DB:?Need POSTGRES_DB in .env or the environment}"
: "${SOURCE_DB:=${POSTGRES_DB}}"
: "${DB_SUPERUSER:=${POSTGRES_USER}}"
: "${DB_SUPERPASS:=${POSTGRES_PASSWORD}}"
: "${BACKEND_HEALTH_URL:=http://127.0.0.1:8000/health}"
: "${FRONTEND_URL:=http://127.0.0.1}"

STAMP="$(date +%Y%m%d_%H%M%S)"
TEMP_DB="${SOURCE_DB}_e2e_${STAMP}_$RANDOM"
ORIGINAL_DATABASE_URL="${DATABASE_URL:-}"

backend_was_running=0
frontend_was_running=0

if [ "$(docker compose ps -q backend 2>/dev/null | wc -l | tr -d ' ')" != "0" ]; then
  backend_was_running=1
fi

if [ "$(docker compose ps -q frontend 2>/dev/null | wc -l | tr -d ' ')" != "0" ]; then
  frontend_was_running=1
fi

cleanup() {
  echo "Cleaning up e2e services and temp DB..."

  docker compose stop backend frontend >/dev/null 2>&1 || true

  docker compose exec -T db bash -lc "
    export PGPASSWORD='${DB_SUPERPASS}';
    psql -U '${DB_SUPERUSER}' -d postgres -c \"
      SELECT pg_terminate_backend(pid)
      FROM pg_stat_activity
      WHERE datname = '${TEMP_DB}'
        AND pid <> pg_backend_pid();
    \" >/dev/null 2>&1 || true

    dropdb -U '${DB_SUPERUSER}' --if-exists '${TEMP_DB}' || true
  " || true

  if [ "${backend_was_running}" -eq 1 ] || [ "${frontend_was_running}" -eq 1 ]; then
    echo "Restoring services that were running before e2e..."
    if [ -n "${ORIGINAL_DATABASE_URL}" ]; then
      DATABASE_URL="${ORIGINAL_DATABASE_URL}" docker compose up -d backend frontend >/dev/null 2>&1 || true
    else
      docker compose up -d backend frontend >/dev/null 2>&1 || true
    fi
  fi
}
trap cleanup EXIT

echo "Starting database container..."
docker compose up -d db

echo "Waiting for Postgres..."
for i in {1..60}; do
  if docker compose exec -T db bash -lc "export PGPASSWORD='${DB_SUPERPASS}'; pg_isready -U '${DB_SUPERUSER}'" >/dev/null 2>&1; then
    READY=1
    break
  fi
  sleep 2
done
if [ "${READY:-0}" -ne 1 ]; then
  echo "Postgres did not become ready"
  exit 1
fi

echo "Creating temp DB: ${TEMP_DB}"
docker compose exec -T db bash -lc "
  export PGPASSWORD='${DB_SUPERPASS}';
  createdb -U '${DB_SUPERUSER}' '${TEMP_DB}'
"

echo "Cloning ${SOURCE_DB} -> ${TEMP_DB}"
docker compose exec -T db bash -lc "
  export PGPASSWORD='${DB_SUPERPASS}';
  pg_dump -U '${DB_SUPERUSER}' --no-owner --no-privileges '${SOURCE_DB}' | psql -U '${DB_SUPERUSER}' '${TEMP_DB}'
"

echo "Starting backend and frontend against cloned DB..."
DATABASE_URL="postgresql+psycopg2://${DB_SUPERUSER}:${DB_SUPERPASS}@db:5432/${TEMP_DB}" \
docker compose up -d --force-recreate backend frontend

echo "Waiting for backend..."
unset READY
for i in {1..60}; do
  if curl -fsS "${BACKEND_HEALTH_URL}" >/dev/null 2>&1; then
    READY=1
    break
  fi
  sleep 2
done
if [ "${READY:-0}" -ne 1 ]; then
  echo "Backend did not become ready"
  docker compose logs backend
  exit 1
fi

echo "Waiting for frontend..."
unset READY
for i in {1..60}; do
  if curl -fsS "${FRONTEND_URL}" >/dev/null 2>&1; then
    READY=1
    break
  fi
  sleep 2
done
if [ "${READY:-0}" -ne 1 ]; then
  echo "Frontend did not become ready"
  docker compose logs frontend
  exit 1
fi

cd "${SCRIPT_DIR}"

if [ ! -d node_modules ]; then
  echo "Installing Playwright dependencies..."
  npm ci
fi

if [ "${SKIP_PLAYWRIGHT_BROWSER_INSTALL:-0}" != "1" ]; then
  npx playwright install
fi

echo "Running Playwright..."
npx playwright test
